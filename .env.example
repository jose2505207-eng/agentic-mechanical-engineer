# Agentic Mechanical Engineer — environment template
# Copy to .env and fill only what you need. See `env-space` for full docs of every variable.
# NEVER commit a real .env file or real secrets.

# --- Core (all optional for the deterministic MVP demo) ---
MODEL_PROVIDER=deterministic
MODEL_NAME=
STORAGE_DIR=./outputs
MAX_CAD_COMPLEXITY=100000
CAD_MAX_ITERATIONS=5
ALLOW_EXTERNAL_PART_SEARCH=false

# --- LLM providers (needed only for the AI agent layer) ---
# Hackathon target: MODEL_PROVIDER=fireworks (get key: https://fireworks.ai
# -> account -> API keys; hackathon grants $50 credits, +$50 for AMD AI
# Developer Program members), or MODEL_PROVIDER=vllm pointing at a
# self-hosted model on AMD Developer Cloud (https://devcloud.amd.com/,
# program signup at https://www.amd.com/en/developer.html, approval 2-3 days).
FIREWORKS_API_KEY=your-fireworks-key-here
VLLM_BASE_URL=http://localhost:8001/v1
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
OPENROUTER_API_KEY=your-openrouter-key-here
# HF token (vLLM HOST only, to pull license-gated Gemma weights):
# https://huggingface.co/settings/tokens + accept the Gemma model license
HF_TOKEN=your-huggingface-token-here

# --- Persistence (optional; local filesystem is the default) ---
DATABASE_URL=postgresql://user:password@localhost:5432/mea
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=server-only-never-expose

# --- Automation / deployment (optional) ---
GITHUB_TOKEN=your-github-token-here
VERCEL_TOKEN=your-vercel-token-here
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
RENDER_API_KEY=
RAILWAY_TOKEN=

# --- ML / observability (optional) ---
HF_TOKEN=your-huggingface-token-here
WANDB_API_KEY=your-wandb-key-here
SENTRY_DSN=

# --- Sourcing / CAD cloud integrations (optional, future) ---
NEXAR_CLIENT_ID=
NEXAR_CLIENT_SECRET=
ONSHAPE_ACCESS_KEY=
ONSHAPE_SECRET_KEY=
